{
    "typeAcquisition": {
        "enable": true,
        "include": []
    },
    "include": [
        "intell/**/intell*.ts",
        "intell/**/globalThis*.ts",
        "intell.ctrl/**/*.ts",
        "intell.portal/**/*.ts"
    ],
    "compilerOptions": {
        "noImplicitAny": false,
        "noEmitOnError": false,
        "removeComments": false,
        "sourceMap": true,
        "declaration": true,
        "target": "es2022",
        "module": "es6",
        "noCheck": true,
        //"composite": true,
        "inlineSources": true,
        "outFile": "../output/production/intell.min.js"
    },
    "compileOnSave": true
}
